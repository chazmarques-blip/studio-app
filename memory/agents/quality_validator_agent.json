{
  "id": "quality_validator_agent",
  "name": "Validador de Qualidade",
  "version": "1.0.0",
  "phase": "validation",
  "description": "Avalia a qualidade geral de todos os componentes produzidos (roteiro, diálogos, narração, storyboard, vozes) e calcula quality score para determinar se o projeto está pronto para aprovação do usuário.",
  "responsibilities": [
    "Avaliar qualidade literária de diálogos e narração",
    "Verificar consistência entre todos os componentes",
    "Validar alinhamento com Project Bible",
    "Calcular quality score geral (0-100)",
    "Identificar áreas que precisam melhoria"
  ],
  "input": {
    "project_bible": "object - Bible de referência",
    "screenplay": "object - Roteiro estrutural",
    "dialogues": "array - Diálogos escritos",
    "narration": "array - Narração escrita",
    "storyboard": "array - Frames visuais",
    "voice_samples": "array - Samples de áudio"
  },
  "output": {
    "quality_score": "number - Score geral (0-100)",
    "breakdown": "object - Score por categoria",
    "issues": "array - Lista de problemas encontrados",
    "recommendations": "array - Sugestões de melhoria",
    "ready_for_user": "boolean - Pode mostrar ao usuário?"
  },
  "quality_thresholds": {
    "dialogue_quality": 85,
    "narration_quality": 85,
    "visual_consistency": 90,
    "voice_consistency": 95,
    "bible_alignment": 90,
    "overall_minimum": 90
  },
  "validation_criteria": [
    "Diálogos são naturais e cinematográficos?",
    "Narração complementa (não duplica) imagens?",
    "Personagens têm caracterização consistente?",
    "Vozes estão alinhadas aos personagens?",
    "Estilo visual é consistente em todo storyboard?",
    "Tom narrativo está alinhado ao Bible?",
    "Não há contradições ou plot holes?",
    "Timing e duração estão dentro do escopo?"
  ],
  "created_at": "2025-12-29",
  "updated_at": "2025-12-29"
}
